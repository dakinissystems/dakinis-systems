{
  "$schema": "./lsp-servers.schema.json",
  "version": 1,
  "description": "LSP Service registry — maps languageId (VS Code compatible) to language server. Extensible without API changes.",
  "servers": [
    { "languageId": "typescript", "serverId": "typescript-language-server", "extensions": [".ts", ".tsx"], "phase": "mvp" },
    { "languageId": "javascript", "serverId": "typescript-language-server", "extensions": [".js", ".jsx", ".mjs", ".cjs"], "phase": "mvp" },
    { "languageId": "python", "serverId": "pyright", "extensions": [".py", ".pyi"], "phase": "mvp" },
    { "languageId": "go", "serverId": "gopls", "extensions": [".go"], "phase": "growth" },
    { "languageId": "rust", "serverId": "rust-analyzer", "extensions": [".rs"], "phase": "growth" },
    { "languageId": "java", "serverId": "jdtls", "extensions": [".java"], "phase": "growth" },
    { "languageId": "kotlin", "serverId": "kotlin-language-server", "extensions": [".kt", ".kts"], "phase": "future" },
    { "languageId": "php", "serverId": "intelephense", "extensions": [".php"], "phase": "growth" },
    { "languageId": "ruby", "serverId": "solargraph", "extensions": [".rb"], "phase": "future" },
    { "languageId": "csharp", "serverId": "csharp-ls", "extensions": [".cs"], "phase": "growth" },
    { "languageId": "fsharp", "serverId": "fsautocomplete", "extensions": [".fs", ".fsi"], "phase": "future" },
    { "languageId": "swift", "serverId": "sourcekit-lsp", "extensions": [".swift"], "phase": "future" },
    { "languageId": "dart", "serverId": "dart-language-server", "extensions": [".dart"], "phase": "growth" },
    { "languageId": "elixir", "serverId": "elixir-ls", "extensions": [".ex", ".exs"], "phase": "future" },
    { "languageId": "scala", "serverId": "metals", "extensions": [".scala", ".sc"], "phase": "future" },
    { "languageId": "cpp", "serverId": "clangd", "extensions": [".cpp", ".cc", ".cxx", ".hpp", ".h"], "phase": "growth" },
    { "languageId": "c", "serverId": "clangd", "extensions": [".c", ".h"], "phase": "growth" },
    { "languageId": "zig", "serverId": "zls", "extensions": [".zig"], "phase": "future" },
    { "languageId": "haskell", "serverId": "haskell-language-server", "extensions": [".hs"], "phase": "future" },
    { "languageId": "lua", "serverId": "lua-language-server", "extensions": [".lua"], "phase": "future" },
    { "languageId": "html", "serverId": "vscode-html-language-server", "extensions": [".html", ".htm"], "phase": "mvp" },
    { "languageId": "css", "serverId": "vscode-css-language-server", "extensions": [".css"], "phase": "mvp" },
    { "languageId": "scss", "serverId": "vscode-css-language-server", "extensions": [".scss", ".sass"], "phase": "growth" },
    { "languageId": "json", "serverId": "vscode-json-language-server", "extensions": [".json", ".jsonc"], "phase": "mvp" },
    { "languageId": "yaml", "serverId": "yaml-language-server", "extensions": [".yaml", ".yml"], "phase": "growth" },
    { "languageId": "markdown", "serverId": "marksman", "extensions": [".md", ".markdown"], "phase": "growth" },
    { "languageId": "sql", "serverId": "sqls", "extensions": [".sql"], "phase": "growth" },
    { "languageId": "dockerfile", "serverId": "dockerfile-language-server", "extensions": ["Dockerfile", ".dockerfile"], "phase": "growth" },
    { "languageId": "terraform", "serverId": "terraform-ls", "extensions": [".tf", ".tfvars"], "phase": "future" },
    { "languageId": "protobuf", "serverId": "buf-language-server", "extensions": [".proto"], "phase": "future" },
    { "languageId": "graphql", "serverId": "graphql-language-server", "extensions": [".graphql", ".gql"], "phase": "future" },
    { "languageId": "vue", "serverId": "volar", "extensions": [".vue"], "phase": "growth" },
    { "languageId": "svelte", "serverId": "svelte-language-server", "extensions": [".svelte"], "phase": "future" },
    { "languageId": "r", "serverId": "languageserver.r", "extensions": [".r", ".R"], "phase": "future" },
    { "languageId": "julia", "serverId": "julia-language-server", "extensions": [".jl"], "phase": "future" },
    { "languageId": "shell", "serverId": "bash-language-server", "extensions": [".sh", ".bash"], "phase": "growth" },
    { "languageId": "plaintext", "serverId": null, "extensions": ["*"], "phase": "mvp", "notes": "Editor only — no LSP required" }
  ],
  "fallback": {
    "languageId": "*",
    "behavior": "editor-only",
    "description": "Any file editable as text; LSP optional via marketplace plugin"
  }
}
