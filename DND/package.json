{
  "name": "dakinis-tabletop",
  "private": true,
  "version": "1.0.0",
  "description": "Tabletop RPG platform for Dakinis Systems — character management, campaigns, and cloud sync.",
  "type": "module",
  "workspaces": [
    "api",
    "web"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c cyan,magenta \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "npm run dev -w @dakinis/tabletop-api",
    "dev:web": "npm run dev -w @dakinis/tabletop-web",
    "build": "npm run build -w @dakinis/tabletop-web",
    "start": "serve web/dist -s -l tcp://0.0.0.0:${PORT:-8080}",
    "start:api": "npm run start -w @dakinis/tabletop-api",
    "preview": "npm run preview -w @dakinis/tabletop-web",
    "migrate-legacy": "node scripts/migrate-legacy-json.mjs"
  },
  "dependencies": {
    "serve": "^14.2.4"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
