{
  "service": "dakinis-internal-api",
  "status": "scaffold",
  "description": "API interna platform — productos nunca hablan entre sí directamente.",
  "baseUrl": "https://api.dakinissystems.com/internal",
  "auth": "Bearer service token (DAKINIS_INTERNAL_SERVICE_KEY)",
  "routes": {
    "GET /internal/health": "Health del servicio internal",
    "GET /internal/users/:id": "Perfil mínimo usuario (IdP)",
    "GET /internal/profile/:userId": "Preferencias cross-producto",
    "GET /internal/hub/dashboard/:userId": "Dashboard Hub — secciones, apps, resumen",
    "POST /internal/events": "Publicar evento al bus platform",
    "GET /internal/events": "Suscripción / replay (admin)",
    "POST /internal/storage/upload-url": "Presigned upload URL → Storage (Supabase / R2)",
    "GET /internal/storage/:objectId": "Signed read URL",
    "POST /internal/search": "Global search (query + scopes)",
    "POST /internal/knowledge/query": "Proxy → Knowledge /v1/query",
    "POST /internal/notifications/send": "Encolar notificación multi-canal"
  },
  "consumers": ["core", "lifeflow", "streamautomator", "akoenet", "hub", "ai"],
  "notes": [
    "Implementación inicial puede vivir en dakinis-hub o servicio dedicado.",
    "Eventos tipados: @dakinis/shared-ai/events.js DAKINIS_EVENTS",
    "No acceso cross-DB entre productos"
  ]
}
