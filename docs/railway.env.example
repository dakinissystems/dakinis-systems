# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_VERIFY_TOKEN=
# WHATSAPP_APP_SECRET=
# WHATSAPP_DEFAULT_BUSINESS_ID=


# ─── Core Front (build Vite — redeploy tras cambiar) ───
# VITE_SENTRY_DSN=
# VITE_SENTRY_ENVIRONMENT=production
# VITE_SENTRY_RELEASE=${{RAILWAY_GIT_COMMIT_SHA}}
# VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
# VITE_SENTRY_REPLAY_SESSION_SAMPLE_RATE=0.05
# VITE_SENTRY_REPLAY_ON_ERROR_SAMPLE_RATE=1

# ─── dakinis-auth ───
# NODE_ENV=production
# PORT=4000
# DATABASE_URL=<misma Supabase URI>
# DATABASE_SSL=true
# AUTH_SCHEMA=dakinis_auth
# JWT_SECRET=<igual que Core>
# JWT_ACCESS_TTL=15m
# JWT_LEGACY_LONG_TTL=false
# REDIS_URL=${{Redis.REDIS_URL}}
# CORS_ORIGINS=https://core.dakinissystems.com,https://akoenet.dakinissystems.com,...

