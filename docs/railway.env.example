# Plantilla variables Railway — copiar por servicio (NO commitear valores reales)
# Base de datos: SUPABASE pooler 6543 (NO Railway Postgres)

# ─── Core Back ───
NODE_ENV=production
PORT=4001
DB_DRIVER=postgres
# Opcional al final: ?pgbouncer=true (misma URI en Core Back y dakinis-auth)
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_SSL=true
POSTGRES_SCHEMA=dakinis_core_prod
CORE_SEED_DEMO=false
JWT_SECRET=
CORS_ORIGIN=https://core.dakinissystems.com
CORE_WEB_URL=https://core.dakinissystems.com
RESEND_API_KEY=
# Recepción @dakinissystems.com vía Cloudflare Email Routing → dakinissystems@gmail.com (catch-all: disabled)
# Envío transaccional vía Resend (dominio streamautomator.com)
RESEND_FROM=Dakinis Systems <noreply@streamautomator.com>
REDIS_URL=${{Redis.REDIS_URL}}
DAKINIS_EVENT_BUS=redis
TRUST_PROXY=true
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
# ─── Stripe (Core Back) ───
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_STARTER_MONTHLY=price_1TicuQE8ho0WJUFPbEqjd52f
