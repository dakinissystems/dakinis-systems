# Plantilla variables Railway — copiar por servicio (NO commitear valores reales)
# Base de datos: SUPABASE pooler 6543 (NO Railway Postgres)

# ─── Core Back ───
NODE_ENV=production
PORT=4001
DB_DRIVER=postgres
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
DATABASE_SSL=true
POSTGRES_SCHEMA=dakinis_core_prod
CORE_SEED_DEMO=false
JWT_SECRET=
CORS_ORIGIN=https://core.dakinissystems.com
REDIS_URL=${{Redis.REDIS_URL}}
DAKINIS_EVENT_BUS=redis
TRUST_PROXY=true
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# ─── dakinis-auth ───
# NODE_ENV=production
# PORT=4000
# DATABASE_URL=<misma Supabase URI>
# DATABASE_SSL=true
# AUTH_SCHEMA=dakinis_auth
# JWT_SECRET=<igual que Core>
# JWT_ACCESS_TTL=15m
# JWT_LEGACY_LONG_TTL=false
# REDIS_URL=${{Redis.REDIS_URL}}
# CORS_ORIGINS=https://core.dakinissystems.com,https://akoenet.dakinissystems.com,...

# ─── akoenet-client (build) ───
# VITE_DAKINIS_AUTH_URL=https://auth.dakinissystems.com/auth
