# Plantilla variables Railway — copiar por servicio (NO commitear valores reales)
# Base de datos: SUPABASE pooler 6543 (NO Railway Postgres)

# ─── Core Back ───
NODE_ENV=production
PORT=4001
DB_DRIVER=postgres
# Opcional al final: ?pgbouncer=true (misma URI en Core Back y dakinis-auth)
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_SSL=true
POSTGRES_SCHEMA=dakinis_core_prod
CORE_SEED_DEMO=false
JWT_SECRET=
CORS_ORIGIN=https://core.dakinissystems.com
REDIS_URL=${{Redis.REDIS_URL}}
DAKINIS_EVENT_BUS=redis
TRUST_PROXY=true
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# ─── Core Front (build Vite — redeploy tras cambiar) ───
# VITE_SENTRY_DSN=
# VITE_SENTRY_ENVIRONMENT=production
# VITE_SENTRY_RELEASE=${{RAILWAY_GIT_COMMIT_SHA}}
# VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
# VITE_SENTRY_REPLAY_SESSION_SAMPLE_RATE=0.05
# VITE_SENTRY_REPLAY_ON_ERROR_SAMPLE_RATE=1

# ─── dakinis-auth ───
# NODE_ENV=production
# PORT=4000
# DATABASE_URL=<misma Supabase URI>
# DATABASE_SSL=true
# AUTH_SCHEMA=dakinis_auth
# JWT_SECRET=<igual que Core>
# JWT_ACCESS_TTL=15m
# JWT_LEGACY_LONG_TTL=false
# REDIS_URL=${{Redis.REDIS_URL}}
# CORS_ORIGINS=https://core.dakinissystems.com,https://akoenet.dakinissystems.com,...

# ─── akoenet-backend ───
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1

# ─── akoenet-client (build) ───
# VITE_DAKINIS_AUTH_URL=https://auth.dakinissystems.com/auth
# VITE_SENTRY_DSN=
# VITE_SENTRY_ENVIRONMENT=production

# ─── streamautomator-api / worker / scheduler ───
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production

# ─── streamautomator-web (build) ───
# VITE_SENTRY_DSN=
# VITE_SENTRY_ENVIRONMENT=production
