# WORKER_TYPE=ingest
# OPENAI_API_KEY=
# DAKINIS_AI_SERVICE_KEY=
# DAKINIS_INTERNAL_SERVICE_KEY=
# STORAGE_PROVIDER=supabase
# STORAGE_BUCKET=knowledge

