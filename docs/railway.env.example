# ─── dakinis-knowledge (PORT=4084) — API + Worker ───
# PORT=4084
# REDIS_URL=${{Redis.REDIS_URL}}
# DATABASE_URL=<Supabase pooler 6543>
# DATABASE_SSL=true
# DAKINIS_SEARCH_URL=https://api.dakinissystems.com/search
