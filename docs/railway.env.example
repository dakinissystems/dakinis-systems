# Plantilla variables Railway — copiar por servicio (NO commitear valores reales)
# Base de datos: SUPABASE pooler 6543 (NO Railway Postgres)

# ─── URLs platform (referencia prod — ver PLATFORM-STATUS.md) ───
# Alias lógico          Variable en repo              Valor prod
# AUTH_URL              VITE_DAKINIS_AUTH_URL           https://auth.dakinissystems.com/auth
# AI_URL (directo)      DAKINIS_AI_URL                  https://ai.dakinissystems.com
# AI_URL (vía gateway)  DAKINIS_AI_BASE_URL             https://api.dakinissystems.com/ai
# CORE_URL (front)      VITE_CORE_URL / CORE_WEB_URL    https://core.dakinissystems.com
# CORE_URL (API)        DAKINIS_GATEWAY_URL + /core     https://api.dakinissystems.com/core
# SEARCH_URL            DAKINIS_SEARCH_URL              https://api.dakinissystems.com/search
# KNOWLEDGE_URL         DAKINIS_KNOWLEDGE_URL           https://api.dakinissystems.com/knowledge
# NOTIFICATIONS_URL     DAKINIS_NOTIFICATIONS_URL       https://api.dakinissystems.com/notifications
# GATEWAY               DAKINIS_GATEWAY_URL             https://api.dakinissystems.com

# ─── Core Back ───
NODE_ENV=production
PORT=4001
DB_DRIVER=postgres
# Opcional al final: ?pgbouncer=true (misma URI en Core Back y dakinis-auth)
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_SSL=true
POSTGRES_SCHEMA=dakinis_core_prod
CORE_SEED_DEMO=false
JWT_SECRET=
CORS_ORIGIN=https://core.dakinissystems.com
CORE_WEB_URL=https://core.dakinissystems.com
RESEND_API_KEY=
# Recepción @dakinissystems.com vía Cloudflare Email Routing → dakinissystems@gmail.com (catch-all: disabled)
# Envío transaccional vía Resend (dominio streamautomator.com)
RESEND_FROM=Dakinis Systems <noreply@streamautomator.com>
REDIS_URL=${{Redis.REDIS_URL}}
# Event bus: memory | redis (lists/streams legacy) | bullmq (recomendado prod)
DAKINIS_EVENT_BUS=bullmq
TRUST_PROXY=true
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_STARTER_MONTHLY=price_1TicuQE8ho0WJUFPbEqjd52f
# STRIPE_PRICE_GROWTH_MONTHLY=price_1TicwhE8ho0WJUFPZ8FJPecr
# STRIPE_PRICE_PRO_MONTHLY=price_1TicxPE8ho0WJUFPxWQRGWki
# STRIPE_PAYMENT_LINK_GROWTH=https://buy.stripe.com/eVq14n2kv7EN9Qf72ZcjS06
# STRIPE_PAYMENT_LINK_PRO=https://buy.stripe.com/5kQ9AT9MX9MVgeD873cjS07
# FRONTEND_URL=https://core.dakinissystems.com

# ─── Core Back — billing via platform (Stripe fuera de Core) ───
# DAKINIS_BILLING_URL=https://api.dakinissystems.com/billing
# DAKINIS_GATEWAY_URL=https://api.dakinissystems.com
# DAKINIS_INTERNAL_SERVICE_KEY=
# DAKINIS_EVENTS_QUEUE=dakinis:events
# REDIS_URL=${{Redis.REDIS_URL}}

# ─── WhatsApp (Core Back) ───
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_VERIFY_TOKEN=
# WHATSAPP_APP_SECRET=
# WHATSAPP_DEFAULT_BUSINESS_ID=


# ─── Core Front (build Vite — redeploy tras cambiar) ───
# VITE_SENTRY_DSN=
# VITE_SENTRY_ENVIRONMENT=production
# VITE_SENTRY_RELEASE=${{RAILWAY_GIT_COMMIT_SHA}}
# VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
# VITE_SENTRY_REPLAY_SESSION_SAMPLE_RATE=0.05
# VITE_SENTRY_REPLAY_ON_ERROR_SAMPLE_RATE=1

# ─── dakinis-auth ───
# NODE_ENV=production
# PORT=4000
# DATABASE_URL=<misma Supabase URI>
# DATABASE_SSL=true
# AUTH_SCHEMA=dakinis_auth
# JWT_SECRET=<igual que Core>
# JWT_ACCESS_TTL=15m
# JWT_LEGACY_LONG_TTL=false
# REDIS_URL=${{Redis.REDIS_URL}}
# CORS_ORIGINS=https://core.dakinissystems.com,https://akoenet.dakinissystems.com,...

# ─── akoenet-backend ───
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1
# RESEND_API_KEY=
# RESEND_FROM=AkoeNet <akonet@streamautomator.com>
# LEGAL_INBOX_EMAIL=privacy@dakinissystems.com
# DMCA_NOTIFY_EMAIL=legal@dakinissystems.com
# VAPID_SUBJECT=mailto:help@dakinissystems.com

# ─── akoenet-client (build) ───
# VITE_API_URL=https://api.akoenet.dakinissystems.com
# VITE_DAKINIS_CORPORATE_URL=https://dakinissystems.com
# VITE_DAKINIS_AUTH_URL=https://auth.dakinissystems.com/auth
# VITE_LEGAL_CONTACT_EMAIL=legal@dakinissystems.com
# VITE_SENTRY_DSN=
# VITE_SENTRY_ENVIRONMENT=production

# ─── streamautomator-api / worker / scheduler ───
# AKOENET_SCHEDULER_WEBHOOK_URL=https://api.akoenet.dakinissystems.com/integrations/scheduler/webhooks/stream-scheduled
# SCHEDULER_WEBHOOK_SECRET=<same as AkoeNet backend>
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production

# ─── streamautomator-web (build) ───
# VITE_SENTRY_DSN=
# VITE_SENTRY_ENVIRONMENT=production

# ─── dakinis-ai (AI API) ───
# NODE_ENV=production
# PORT=4020
# DATABASE_URL=<Supabase pooler 6543>
# POSTGRES_SCHEMA=ai
# DATABASE_SSL=true
# REDIS_URL=${{Redis.REDIS_URL}}
# OPENAI_API_KEY=
# DAKINIS_AI_SERVICE_KEY=<32+ chars, igual en Core Back>
# CORS_ORIGIN=https://core.dakinissystems.com,https://hub.dakinissystems.com
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production

# ─── dakinis-ai-worker (sin dominio público) ───
# WORKER_MODE=true
# REDIS_URL=${{Redis.REDIS_URL}}
# DATABASE_URL=<Supabase pooler 6543>
# POSTGRES_SCHEMA=ai
# OPENAI_API_KEY=
# DAKINIS_AI_SERVICE_KEY=

# ─── dakinis-hub (build) ───
# VITE_DAKINIS_AUTH_URL=https://auth.dakinissystems.com/auth
# VITE_GATEWAY_URL=https://api.dakinissystems.com
# VITE_CORE_URL=https://core.dakinissystems.com
# VITE_HUB_URL=https://hub.dakinissystems.com
# VITE_STREAM_URL=https://streamautomator.com
# VITE_AKOENET_URL=https://akoenet.dakinissystems.com
# VITE_SENTRY_DSN=
# VITE_SENTRY_ENVIRONMENT=production

# ─── Core Back — proxy IA (añadir cuando AI esté en Railway) ───
# DAKINIS_AI_BASE_URL=https://api.dakinissystems.com/ai
# DAKINIS_AI_SERVICE_KEY=<mismo que dakinis-ai>
# OPENAI_API_KEY=  ← eliminar de Core cuando AI prod estable

# ─── Platform services (gateway prefix o URL directa Railway) ───
# DAKINIS_GATEWAY_URL=https://api.dakinissystems.com
# DAKINIS_BILLING_URL=https://api.dakinissystems.com/billing
# DAKINIS_NOTIFICATIONS_URL=https://api.dakinissystems.com/notifications
# DAKINIS_SEARCH_URL=https://api.dakinissystems.com/search
# DAKINIS_KNOWLEDGE_URL=https://api.dakinissystems.com/knowledge
# DAKINIS_INTERNAL_URL=https://api.dakinissystems.com/internal
# DAKINIS_INTERNAL_SERVICE_KEY=

# ─── dakinis-billing (PORT=4080) ───
