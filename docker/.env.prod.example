# Plantilla para `.env.prod` (gitignored). NO commitees secretos reales.
# Uso: define `ENV=prod` en `docker/.env` y mantén credenciales en `.env.prod`.
#
#   Copy-Item .env.prod.example .env.prod
#   # edita JWT_SECRET, URLs de DB gestionadas, etc.

NODE_ENV=production

JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET_MIN_32_CHARS

AUTH_PORT=4000
CORE_API_PORT=4001
STREAMAUTOMATOR_API_PORT=4002
AKOENET_PORT=4003

# Ajusta host/puerto según tu Postgres gestionado (RDS, Cloud SQL, etc.).
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/dakinis
