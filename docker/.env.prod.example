# Template for `.env.prod` (gitignored). Never commit real secrets.
# Enable with:
#   - set ENV=prod in docker/.env
#   - copy this file to docker/.env.prod and fill secrets

NODE_ENV=production

# Required JWT setup (shared across services that validate central identity).
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET_MIN_32_CHARS
JWT_ISSUER=platform-auth
JWT_AUDIENCE=dakinis-platform

# Public URL for StreamAutomator callbacks/webhooks.
BACKEND_URL=https://your-streamautomator-api.example.com

# Strongly recommended in prod after migration.
JWT_STRICT_ISS_AUD=true

# Optional integrations.
# SUPABASE_URL=
# SUPABASE_SERVICE_KEY=
# TWITCH_CLIENT_ID=
# TWITCH_CLIENT_SECRET=
# TWITCH_OAUTH_REDIRECT_BASE_URL=https://your-streamautomator-api.example.com
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=
# DISCORD_BOT_TOKEN=
# STRIPE_SECRET_KEY=            # StreamAutomator only
# STRIPE_WEBHOOK_SECRET=        # StreamAutomator only
