# Template para `docker/.env.prod` (gitignored). Never commit real secrets.

NODE_ENV=production

JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET_MIN_32_CHARS
JWT_ISSUER=platform-auth
JWT_AUDIENCE=dakinis-platform

JWT_STRICT_ISS_AUD=true

BACKEND_URL=https://your-streamautomator-api.example.com
TWITCH_OAUTH_REDIRECT_BASE_URL=https://your-streamautomator-api.example.com

# Twitch por producto (recomendado; compose sobrescribe en cada servicio)
TWITCH_CLIENT_ID_STREAMAUTOMATOR=
TWITCH_CLIENT_SECRET_STREAMAUTOMATOR=
TWITCH_CLIENT_ID_AKOENET=
TWITCH_CLIENT_SECRET_AKOENET=

# Supabase PostgreSQL (pooler 6543) — MISMA URI en dakinis-auth y Core Back (Railway)
# NO uses ${{Postgres.DATABASE_URL}} de Railway si Supabase es tu DB principal.
# DATABASE_URL=postgresql://postgres.PROJECT_REF:URL_ENCODED_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
# DATABASE_SSL=true
# Validar local: .\scripts\validate-database-url.ps1 (con $env:DATABASE_URL)

# Core Back (Railway servicio dakinis-core-api)
# DB_DRIVER=postgres
# POSTGRES_SCHEMA=dakinis_core_prod
# CORE_SEED_DEMO=false

# Auth (Railway dakinis-auth)
# AUTH_SCHEMA=dakinis_auth
# JWT_LEGACY_LONG_TTL=false

SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
# SUPABASE_SERVICE_KEY=        # legacy si tu código sólo usa este nombre

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

DISCORD_CLIENT_ID=
DISCORD_PUBLIC_KEY=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=

STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_DESTINATION_ACCOUNT_ID=
STRIPE_WEBHOOK_SECRET=

RESEND_API_KEY=

# Retrocompat
# TWITCH_CLIENT_ID=
# TWITCH_CLIENT_SECRET=
