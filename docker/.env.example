# Copy to `.env` (docker/.env is gitignored).
# This file only selects which env_file compose should load:
#   env_file: .env.${ENV:-dev}
# Use:
#   ENV=dev   -> loads docker/.env.dev
#   ENV=prod  -> loads docker/.env.prod

ENV=dev

# Opcional — Postgres remoto (p. ej. Supabase). Copia a docker/.env junto con ENV=
# para que compose.full.yml interpole DATABASE_URL en auth/streamautomator/akoenet.
# DATABASE_URL_AUTH=
# DATABASE_URL_STREAMAUTOMATOR=
# DATABASE_URL_AKOENET=
