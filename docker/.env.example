# Copy to .env and adjust (docker/.env is gitignored).
# Paths assume containers on network `dakinis` (see docker-compose.yml).

NODE_ENV=development

# Shared signing secret for auth + consumers (set a long random string in real deployments).
JWT_SECRET=supersecret_local_only_change_in_production_min_32_chars

# Service ports inside containers (compose sets these; listed for documentation).
AUTH_PORT=4000
CORE_API_PORT=4001
STREAMAUTOMATOR_API_PORT=4002
AKOENET_PORT=4003

# Default Postgres URL for auth service (override per-service in compose if needed).
DATABASE_URL=postgres://dakinis:dakinis@postgres:5432/dakinis
