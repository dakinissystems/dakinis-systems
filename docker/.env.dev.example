# Copia a `.env.dev` (gitignored). Variables compartidas por los servicios del stack completo.
#   Copy-Item .env.dev.example .env.dev

NODE_ENV=development

# Secreto de firma JWT (auth + consumidores). En producción usa un valor largo y aleatorio.
JWT_SECRET=supersecret_local_only_change_in_production_min_32_chars

# Documentación — los puertos los fija compose; no hace falta cambiarlos salvo conflicto local.
AUTH_PORT=4000
CORE_API_PORT=4001
STREAMAUTOMATOR_API_PORT=4002
AKOENET_PORT=4003

# URL por defecto para auth (sobrescrita en compose para el servicio auth).
DATABASE_URL=postgres://dakinis:dakinis@postgres:5432/dakinis
