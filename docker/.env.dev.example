# Copia a `docker/.env.dev` (gitignored en la raíz del control repo).
# Compose carga este archivo cuando `docker/.env` define ENV=dev.
#
# ⚠️ Nunca subas valores reales a Git: rota cualquier secreto que haya aparecido en chat/PR/logs.

NODE_ENV=development
LOG_LEVEL=info

# --- JWT compartidos (auth + productos que verifican el mismo secreto en dev)
JWT_SECRET=REPLACE_WITH_LOCAL_SECRET_MIN_32_CHARS
JWT_ISSUER=platform-auth
JWT_AUDIENCE=dakinis-platform

JWT_CORE_ISSUER=dakinis-core
JWT_CORE_AUDIENCE=dakinis-core-api
JWT_STREAMAUTOMATOR_ISSUER=streamautomator-api
JWT_STREAMAUTOMATOR_AUDIENCE=streamautomator
JWT_AKOENET_ISSUER=akoenet-api
JWT_AKOENET_AUDIENCE=akoenet

# --- Core API
DAKINIS_MASTER_API_KEY=dakinis-dev-key

BACKEND_URL=http://localhost:4002

# --- StreamAutomator (Scheduler) API — puerto host 4002
JWT_EXPIRY=7d
SESSION_SECRET=change_me_local_session_secret
DATABASE_SSL=false
TWITCH_OAUTH_REDIRECT_BASE_URL=http://localhost:4002
STRIPE_TAX_ENABLED=false
TRUST_GATEWAY_IDENTITY_HEADERS=true

# Twitch dedicado Scheduler (compose inyecta esto en streamautomator-api)
TWITCH_CLIENT_ID_STREAMAUTOMATOR=your-scheduler-twitch-client-id
TWITCH_CLIENT_SECRET_STREAMAUTOMATOR=your-scheduler-twitch-client-secret

DISCORD_CLIENT_ID=your-discord-application-id
# Clave pública de la aplicación (verificación de interacciones / OAuth según uso del repo)
DISCORD_PUBLIC_KEY=your-discord-application-public-key-hex
DISCORD_CLIENT_SECRET=your-discord-client-secret
DISCORD_BOT_TOKEN=your-discord-bot-token

STRIPE_PUBLISHABLE_KEY=pk_test_or_live_replace_me
STRIPE_SECRET_KEY=sk_test_or_live_replace_me
# "ID de destino" Stripe (nombre exacto según tu integración Connect/Tax/checkout — revisa streamautomator)
STRIPE_DESTINATION_ACCOUNT_ID=
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# OAuth Google (suele usarse en login/calendar según la app que lo consuma)
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

SCHEDULER_WEBHOOK_SECRET=change-me

# --- AkoeNet — puerto host 4003
TOKEN_VERSION=2

# Twitch dedicado AkoeNet (compose inyecta esto en akoenet-backend)
TWITCH_CLIENT_ID_AKOENET=your-akoenet-twitch-client-id
TWITCH_CLIENT_SECRET_AKOENET=your-akoenet-twitch-client-secret

VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=YOUR_VAPID_PRIVATE_KEY
VAPID_SUBJECT=mailto:you@example.com

S3_ENDPOINT=http://host.docker.internal:9000
S3_REGION=us-east-1
S3_BUCKET=akonet
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
STORAGE_PUBLIC_BASE_URL=http://host.docker.internal:9000/akonet
STORAGE_DRIVER=local
S3_USE_PRESIGNED_URLS=true
S3_SIGNED_URL_TTL_SECONDS=900

GLOBAL_RATE_LIMIT_MAX=400
DATABASE_POOL_MAX=20
UPLOAD_RATE_LIMIT_MAX=20
AUTH_RATE_LIMIT_MAX=10
USER_DATA_RATE_LIMIT_MAX=20
SOCKET_MESSAGE_RATE_LIMIT_MAX=40
SOCKET_DM_RATE_LIMIT_MAX=30
REACTION_RATE_LIMIT_MAX=10
REPORT_RATE_LIMIT_MAX=15
EXPORT_MAX_MESSAGES=10000

SCHEDULER_ANNOUNCE_CHANNEL_ID=
SCHEDULER_ANNOUNCER_USER_ID=
SCHEDULER_BOT_AVATAR_URL=
SCHEDULER_UPCOMING_PATH=/api/streamer/{username}/events
SCHEDULER_UPCOMING_URL_TEMPLATE=
SCHEDULER_API_TOKEN=
SCHEDULER_DEFAULT_STREAMER_USERNAME=
SCHEDULER_SOCKET_RATE_LIMIT_MAX=15
SCHEDULER_LIST_MAX=5

TWITCH_REDIRECT_URI=
CORS_ORIGINS=http://localhost:5173

DPO_NAME=
DPO_EMAIL=
DPO_PHONE=
DPO_ADDRESS=
RESEND_API_KEY=

# --- Supabase (URL del proyecto + claves formato sb_* o service_role legacy)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_OR_anon_REPLACE_ME
# Secreto server-side — nunca en front ni en ejemplo versionado real
SUPABASE_SECRET_KEY=sb_secret_OR_service_role_REPLACE_ME
# Si AkoeNet/Server sólo lee la variable legacy:
SUPABASE_SERVICE_KEY=

# Opcional — alias cliente:
# SUPABASE_ANON_KEY=${SUPABASE_PUBLISHABLE_KEY}

# --- Retrocompat Twitch “único”: si defines solo estos, siguen llegando al env_file hasta que compose aplique overrides
# TWITCH_CLIENT_ID=
# TWITCH_CLIENT_SECRET=

# TOKEN_ENCRYPTION_KEY=
