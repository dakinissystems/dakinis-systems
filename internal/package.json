{
  "name": "dakinis-internal-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Platform Internal API — event bus, cross-product server-to-server",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "health": "node -e \"fetch('http://127.0.0.1:'+(process.env.PORT||4083)+'/health').then(r=>r.json()).then(console.log)\""
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@dakinis/domain": "file:./packages/domain",
    "@dakinis/shared-ai": "file:./packages/shared-ai",
    "@dakinis/shared-platform": "file:./packages/shared-platform",
    "@dakinis/shared-db": "file:./packages/shared-db",
    "@dakinis/shared-error": "file:./packages/shared-error",
    "@dakinis/shared-validation": "file:./packages/shared-validation",
    "bullmq": "^5.41.0",
    "pg": "^8.22.0",
    "redis": "^5.5.6"
  }
}
