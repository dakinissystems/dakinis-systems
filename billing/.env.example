NODE_ENV=development
PORT=4080
TRUST_PROXY=true

# Supabase pooler (schema billing)
DATABASE_URL=postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_SSL=true
POSTGRES_SCHEMA=billing

# Stripe (migrate from Core → billing service in Railway)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRODUCT_STARTER=prod_...
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRODUCT_GROWTH=prod_...
STRIPE_PRICE_GROWTH_MONTHLY=price_...
STRIPE_PRODUCT_PRO=prod_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PAYMENT_LINK_GROWTH=https://buy.stripe.com/...
STRIPE_PAYMENT_LINK_PRO=https://buy.stripe.com/...

# StreamAutomator plans (billing unificado — migracion 045/046)
STRIPE_PRODUCT_SA_CREATOR=prod_...
STRIPE_PRICE_SA_CREATOR_MONTHLY=price_...
STRIPE_PRODUCT_SA_PRO=prod_...
STRIPE_PRICE_SA_PRO_MONTHLY=price_...
STRIPE_PRODUCT_SA_LIFETIME=prod_...
STRIPE_PRICE_SA_LIFETIME=price_...

FRONTEND_URL=https://core.dakinissystems.com

# Service-to-service (Internal API / SA fan-out)
INTERNAL_API_KEY=
DAKINIS_INTERNAL_SERVICE_KEY=
STREAMAUTOMATOR_INTERNAL_URL=https://api.streamautomator.com

REDIS_URL=redis://localhost:6379
DAKINIS_EVENTS_QUEUE=dakinis:events
# DAKINIS_EVENT_BUS=bullmq

# Fallback sync Core (HTTP además de BullMQ — usa gateway si no hay URL directa)
# DAKINIS_GATEWAY_URL=https://api.dakinissystems.com
# DAKINIS_CORE_INTERNAL_URL=https://api.dakinissystems.com/core

SENTRY_DSN=
SENTRY_ENVIRONMENT=development
